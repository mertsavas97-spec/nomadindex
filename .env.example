# Public site URL — required in production for correct canonicals, sitemap, OG, and JSON-LD.
# Example: https://nomadindex.app (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://nomadindex.app

# Google Analytics 4 measurement ID (public site tracking)
# Example: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Vercel sets VERCEL_URL automatically on preview/production when NEXT_PUBLIC_SITE_URL is unset.
# Always set NEXT_PUBLIC_SITE_URL on the production domain in Vercel project settings.

# Admin CMS authentication (required for /admin)
ADMIN_PASSWORD=

# Optional: separate signing secret for admin session cookies (falls back to ADMIN_PASSWORD)
# ADMIN_SESSION_SECRET=

# Optional: SQLite database path (defaults to ./data/cms.db)
# CMS_DATABASE_PATH=./data/cms.db

# Google Analytics 4 Data API (optional — enables /admin/analytics dashboard)
# GA_PROPERTY_ID=
# GOOGLE_CLIENT_EMAIL=
# GOOGLE_PRIVATE_KEY=
