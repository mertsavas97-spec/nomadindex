# Public site URL — required in production for correct canonicals, sitemap, OG, and JSON-LD.
# Example: https://nomadindex.app (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://nomadindex.app

# Google Analytics 4 measurement ID (public site tracking)
# Example: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Admin CMS authentication (required for /admin)
ADMIN_PASSWORD=

# Optional: separate signing secret for admin session cookies (falls back to ADMIN_PASSWORD)
# ADMIN_SESSION_SECRET=

# Git-first CMS — GitHub API (required for admin saves in production)
# Fine-grained or classic PAT with contents: read/write on the repo
GITHUB_TOKEN=
GITHUB_REPO=owner/nomadindex-app
GITHUB_BRANCH=main

# Vercel Deploy Hook — triggered after each CMS commit
VERCEL_DEPLOY_HOOK_URL=

# Vercel API — optional, enables deployment status polling in /admin
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=

# Google Analytics 4 Data API (optional — enables /admin/analytics dashboard)
# GA_PROPERTY_ID=
# GOOGLE_CLIENT_EMAIL=
# GOOGLE_PRIVATE_KEY=
